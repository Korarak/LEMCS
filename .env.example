# Environment variables for LEMCS

# App
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=True

# Database
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=5432
POSTGRES_DB=lemcs
POSTGRES_USER=lemcs_user
POSTGRES_PASSWORD=change_this_password

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change_this_secret_key_min_32_chars_for_jwt_signing_token
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_minio_password

# LINE / SMS / SMTP (Optional based on features)
LINE_NOTIFY_TOKEN=your_line_notify_token
SMS_API_KEY=your_sms_api_key
SMS_API_URL=https://smsapi.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=secret

# PDPA Encryption Key
ENCRYPTION_KEY=12345678901234567890123456789012 # 32 chars exactly for AES-256

# Monitoring
GRAFANA_PASSWORD=admin
